{
  "name": "things-to-eat-and-do",
  "version": "1.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start --lan",
    "start:localhost": "expo start --localhost",
    "start:tunnel": "expo start --tunnel",
    "start:web": "expo start --web --localhost",
    "android": "expo run:android",
    "build:android": "eas build --platform android --profile production",
    "build:web": "expo export -p web",
    "lint": "echo \"Add eslint config when project grows\"",
    "test:route-import": "tsc --module commonjs --target ES2020 --skipLibCheck --esModuleInterop --outDir .route-import-test-build routeImport.ts routeHandoff.ts && node --test tests/routeImport.test.js tests/routeHandoff.test.js",
    "test": "npm run test:route-import"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "latest",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.35",
    "expo-font": "~14.0.12",
    "expo-location": "~19.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.1.10",
    "eas-cli": "latest",
    "sharp": "^0.34.5",
    "typescript": "latest"
  }
}
